<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_branch_physical_inventory_warehouse_wizard_form" model="ir.ui.view">
            <field name="name">branch.physical.inventory.warehouse.wizard.form</field>
            <field name="model">kio.branch.physical.inventory.warehouse.wizard</field>
            <field name="arch" type="xml">
                <form string="Select Warehouse">
                    <sheet>
                        <group>
                            <field name="warehouse_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_open_physical_inventory" string="Open Inventory" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_branch_physical_inventory_warehouse_wizard" model="ir.actions.act_window">
            <field name="name">Select Warehouse</field>
            <field name="res_model">kio.branch.physical.inventory.warehouse.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
        <record id="view_branch_physical_inventory_quant_tree" model="ir.ui.view">
            <field name="name">branch.physical.inventory.quant.tree</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <tree string="Physical Inventory" editable="bottom" create="0" delete="0" multi_edit="1" js_class="branch_physical_inventory_barcode_list" default_order="branch_inventory_warehouse_id, location_id, product_id">
                    <header>
                        <button name="action_branch_approve_inventory" string="Approve" type="object" class="btn-primary" display="always" confirm="Approve the saved counted quantities and update stock?"/>
                    </header>
                    <field name="branch_inventory_warehouse_id" optional="show" readonly="1"/>
                    <field name="location_id" optional="show" readonly="1"/>
                    <field name="product_id" optional="show" readonly="1"/>
                    <field name="product_categ_id" optional="hide" readonly="1"/>
                    <field name="lot_id" optional="hide" readonly="1" groups="stock.group_production_lot"/>
                    <field name="package_id" optional="hide" readonly="1" groups="stock.group_tracking_lot"/>
                    <field name="owner_id" optional="hide" readonly="1" groups="stock.group_tracking_owner"/>
                    <field name="quantity" string="System Quantity" optional="show" readonly="1"/>
                    <field name="reserved_quantity" optional="hide" readonly="1"/>
                    <field name="available_quantity" optional="show" readonly="1"/>
                    <field name="inventory_quantity" string="Counted Quantity" optional="show"/>
                    <field name="inventory_diff_quantity" string="Difference" optional="show" readonly="1"/>
                    <field name="product_uom_id" string="UoM" optional="show" readonly="1"/>
                    <field name="inventory_date" optional="hide"/>
                    <field name="user_id" string="Assigned To" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_branch_physical_inventory_quant_form" model="ir.ui.view">
            <field name="name">branch.physical.inventory.quant.form</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <form string="Physical Inventory">
                    <header>
                        <button name="action_branch_approve_inventory" string="Approve" type="object" class="btn-primary" display="always" confirm="Approve the saved counted quantities and update stock?"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="product_id" readonly="1"/>
                                <field name="product_categ_id" readonly="1"/>
                                <field name="branch_inventory_warehouse_id" readonly="1"/>
                                <field name="location_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="quantity" string="System Quantity" readonly="1"/>
                                <field name="available_quantity" readonly="1"/>
                                <field name="inventory_quantity" string="Counted Quantity"/>
                                <field name="inventory_diff_quantity" string="Difference" readonly="1"/>
                                <field name="product_uom_id" readonly="1"/>
                            </group>
                        </group>
                        <group string="Tracking">
                            <field name="lot_id" readonly="1" groups="stock.group_production_lot"/>
                            <field name="package_id" readonly="1" groups="stock.group_tracking_lot"/>
                            <field name="owner_id" readonly="1" groups="stock.group_tracking_owner"/>
                            <field name="inventory_date"/>
                            <field name="user_id" string="Assigned To"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_branch_physical_inventory_quant_search" model="ir.ui.view">
            <field name="name">branch.physical.inventory.quant.search</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <search string="Search Physical Inventory">
                    <field name="product_id" string="Product" filter_domain="[('product_id', 'ilike', self)]"/>
                    <field name="branch_inventory_warehouse_id" string="Warehouse"/>
                    <field name="location_id" string="Location"/>
                    <field name="product_categ_id" string="Product Category"/>
                    <field name="lot_id" string="Lot/Serial Number" groups="stock.group_production_lot"/>
                    <field name="owner_id" string="Owner" groups="stock.group_tracking_owner"/>
                    <separator/>
                    <filter name="has_count" string="Draft Counts" domain="[('inventory_quantity_set', '=', True)]"/>
                    <filter name="not_counted" string="No Draft Count" domain="[('inventory_quantity_set', '=', False)]"/>
                    <filter name="has_difference" string="Difference" domain="[('inventory_diff_quantity', '!=', 0)]"/>
                    <filter name="available_products" string="Available Products" domain="[('branch_inventory_available_product', '=', True)]"/>
                    <separator/>
                    <filter name="group_warehouse" string="Warehouse" context="{'group_by': 'branch_inventory_warehouse_id'}"/>
                    <filter name="group_location" string="Location" context="{'group_by': 'location_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <searchpanel>
                        <field name="branch_inventory_warehouse_id" string="Warehouses" enable_counters="1"/>
                        <field name="location_id" string="Locations" enable_counters="1"/>
                    </searchpanel>
                </search>
            </field>
        </record>

        <record id="action_branch_physical_inventory" model="ir.actions.act_window">
            <field name="name">Physical Inventory Audit</field>
            <field name="res_model">stock.quant</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_branch_physical_inventory_quant_search"/>
            <field name="domain">[('location_id.usage', '=', 'internal')]</field>
            <field name="context">{'inventory_mode': True}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No products found for this warehouse or filter.</p>
                <p>Use the warehouse panel, product search, and filters to find items. Save counted quantities as draft, then approve to update stock.</p>
            </field>
        </record>

        <record id="action_branch_physical_inventory_tree_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_branch_physical_inventory_quant_tree"/>
            <field name="act_window_id" ref="action_branch_physical_inventory"/>
        </record>

        <record id="action_branch_physical_inventory_form_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_branch_physical_inventory_quant_form"/>
            <field name="act_window_id" ref="action_branch_physical_inventory"/>
        </record>

        <record id="view_branch_inventory_quant_update_log_tree" model="ir.ui.view">
            <field name="name">branch.inventory.quant.update.log.tree</field>
            <field name="model">kio.branch.inventory.quant.update.log</field>
            <field name="arch" type="xml">
                <tree string="Quantity Update History" create="0" edit="0" delete="0" default_order="approved_date desc">
                    <field name="approved_date"/>
                    <field name="approved_by_id"/>
                    <field name="warehouse_id"/>
                    <field name="location_id"/>
                    <field name="product_id"/>
                    <field name="previous_quantity"/>
                    <field name="counted_quantity"/>
                    <field name="difference_quantity"/>
                    <field name="product_uom_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </tree>
            </field>
        </record>

        <record id="view_branch_inventory_quant_update_log_form" model="ir.ui.view">
            <field name="name">branch.inventory.quant.update.log.form</field>
            <field name="model">kio.branch.inventory.quant.update.log</field>
            <field name="arch" type="xml">
                <form string="Quantity Update History" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="approved_date"/>
                                <field name="approved_by_id"/>
                                <field name="product_id"/>
                                <field name="product_uom_id"/>
                            </group>
                            <group>
                                <field name="warehouse_id"/>
                                <field name="location_id"/>
                                <field name="previous_quantity"/>
                                <field name="counted_quantity"/>
                                <field name="difference_quantity"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_branch_inventory_quant_update_log_search" model="ir.ui.view">
            <field name="name">branch.inventory.quant.update.log.search</field>
            <field name="model">kio.branch.inventory.quant.update.log</field>
            <field name="arch" type="xml">
                <search string="Search Quantity Updates">
                    <field name="product_id"/>
                    <field name="warehouse_id"/>
                    <field name="location_id"/>
                    <field name="approved_by_id"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="group_warehouse" string="Warehouse" context="{'group_by': 'warehouse_id'}"/>
                    <filter name="group_user" string="Updated By" context="{'group_by': 'approved_by_id'}"/>
                    <filter name="group_date" string="Updated Date" context="{'group_by': 'approved_date:day'}"/>
                </search>
            </field>
        </record>

        <record id="action_branch_inventory_quant_update_log" model="ir.actions.act_window">
            <field name="name">Quantity Update History</field>
            <field name="res_model">kio.branch.inventory.quant.update.log</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_branch_inventory_quant_update_log_search"/>
        </record>
    </data>
</odoo>
