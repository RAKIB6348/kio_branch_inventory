<odoo>
    <data>
        <record id="view_branch_warehouse_user_tree" model="ir.ui.view">
            <field name="name">kio.branch.warehouse.user.tree</field>
            <field name="model">kio.branch.warehouse.user</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="warehouse_id"/>
                    <field name="company_id"/>
                    <field name="location_id"/>
                    <field name="user_id"/>
                </tree>
            </field>
        </record>

        <record id="view_branch_warehouse_user_form" model="ir.ui.view">
            <field name="name">kio.branch.warehouse.user.form</field>
            <field name="model">kio.branch.warehouse.user</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group string="Warehouse Info">
                                <field name="warehouse_id"/>
                                <field name="company_id"/>
                            </group>

                            <group string="User &amp; Location">
                                <field name="location_id"
                                       domain="[('usage', '=', 'internal'), ('warehouse_id', '=', warehouse_id)]"
                                       force_save="1"/>
                                <field name="user_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_branch_warehouse_user" model="ir.actions.act_window">
            <field name="name">Warehouse User</field>
            <field name="res_model">kio.branch.warehouse.user</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_warehouse_user"
                  name="Warehouse User"
                  parent="stock.menu_stock_config_settings"
                  action="action_branch_warehouse_user"
                  sequence="6"
                  groups="stock.group_stock_manager"/>
    </data>
</odoo>
