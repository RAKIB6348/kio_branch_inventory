<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_branch_product_stock" model="ir.actions.report">
            <field name="name">Product Report</field>
            <field name="model">product.product</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">kio_branch_inventory.report_branch_product_stock</field>
            <field name="report_file">kio_branch_inventory.report_branch_product_stock</field>
            <field name="print_report_name">'Product Stock Report'</field>

            <!-- This line shows report in product.product Print menu -->
            <field name="binding_model_id" ref="product.model_product_product"/>
            <field name="binding_type">report</field>
            <field name="binding_view_types">list,form</field>

            <!-- User and Admin both can download PDF -->
            <field name="groups_id" eval="[(6, 0, [
                ref('kio_branch_inventory.group_branch_inventory_user'),
                ref('kio_branch_inventory.group_branch_inventory_admin')
            ])]"/>
        </record>

        <template id="report_branch_product_stock">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 13px;">

                        <h2 style="text-align: center; margin-bottom: 10px; font-size: 24px; font-weight: bold;">
                            Warehouse Wise / All Warehouse Product Stock Report
                        </h2>

                        <table style="width: 100%; margin-bottom: 16px; font-size: 13px; border-collapse: collapse;">
                            <tr>
                                <td style="padding: 5px; border: 1px solid #000;">
                                    <strong>Company:</strong>
                                    <span t-esc="company.name"/>
                                </td>
                                <td style="padding: 5px; border: 1px solid #000;">
                                    <strong>Report Type:</strong>
                                    <span t-esc="report_type_label"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 5px; border: 1px solid #000;">
                                    <strong>Selected Warehouse:</strong>
                                    <span t-esc="selected_branch"/>
                                </td>
                                <td style="padding: 5px; border: 1px solid #000;">
                                    <strong>Generated By:</strong>
                                    <span t-esc="generated_by.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 5px; border: 1px solid #000;">
                                    <strong>Generated Date &amp; Time:</strong>
                                    <span t-esc="generated_at.strftime('%Y-%m-%d %H:%M:%S')"/>
                                </td>
                                <td style="padding: 5px; border: 1px solid #000;">
                                    <strong>Filters:</strong>

                                    <span t-if="wizard and wizard.category_id">
                                        Category:
                                        <span t-esc="wizard.category_id.display_name"/>
                                    </span>

                                    <span t-if="wizard and wizard.product_id">
                                        Product:
                                        <span t-esc="wizard.product_id.display_name"/>
                                    </span>

                                    <span t-if="wizard and wizard.active_products_only">
                                        Active Products Only
                                    </span>

                                    <span t-if="not wizard">
                                        Selected Products
                                    </span>
                                </td>
                            </tr>
                        </table>

                        <table class="table table-sm o_main_table"
                               style="width: 100%; font-size: 12.5px; border-collapse: collapse;">
                            <thead>
                                <tr>
                                    <th style="text-align: right; padding: 5px; border: 1px solid #000;">SL</th>
                                    <th style="padding: 5px; border: 1px solid #000;">Warehouse</th>
                                    <th style="padding: 5px; border: 1px solid #000;">Product Name</th>
                                    <th style="padding: 5px; border: 1px solid #000;">Internal Reference</th>
                                    <th style="padding: 5px; border: 1px solid #000;">Product Category</th>
                                    <th style="text-align: right; padding: 5px; border: 1px solid #000;">On Hand</th>
                                    <th style="text-align: right; padding: 5px; border: 1px solid #000;">Free</th>
                                    <th style="text-align: right; padding: 5px; border: 1px solid #000;">Incoming</th>
                                    <th style="text-align: right; padding: 5px; border: 1px solid #000;">Outgoing</th>
                                    <th style="padding: 5px; border: 1px solid #000;">UoM</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr t-foreach="rows" t-as="row">
                                    <td style="text-align: right; padding: 5px; border: 1px solid #000;">
                                        <span t-esc="row['serial']"/>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #000;">
                                        <span t-esc="row['warehouse']"/>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #000;">
                                        <span t-esc="row['product']"/>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #000;">
                                        <span t-esc="row['default_code']"/>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #000;">
                                        <span t-esc="row['category']"/>
                                    </td>
                                    <td style="text-align: right; padding: 5px; border: 1px solid #000;">
                                        <span t-esc="'%.2f' % row['qty_available']"/>
                                    </td>
                                    <td style="text-align: right; padding: 5px; border: 1px solid #000;">
                                        <span t-esc="'%.2f' % row['free_qty']"/>
                                    </td>
                                    <td style="text-align: right; padding: 5px; border: 1px solid #000;">
                                        <span t-esc="'%.2f' % row['incoming_qty']"/>
                                    </td>
                                    <td style="text-align: right; padding: 5px; border: 1px solid #000;">
                                        <span t-esc="'%.2f' % row['outgoing_qty']"/>
                                    </td>
                                    <td style="padding: 5px; border: 1px solid #000;">
                                        <span t-esc="row['uom']"/>
                                    </td>
                                </tr>

                                <tr t-if="not rows">
                                    <td colspan="10" style="text-align: center; padding: 8px; border: 1px solid #000;">
                                        No stock data found.
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <table style="width: 55%; margin-top: 14px; font-size: 12px; border-collapse: collapse; border: 1px solid #000; page-break-inside: avoid;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px; width: 70%;">
                                    <strong>Total Products</strong>
                                </td>
                                <td style="border: 1px solid #000; padding: 5px; width: 30%; text-align: right;">
                                    <strong>
                                        <span t-esc="totals['total_products']"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px;">
                                    <strong>Total On Hand Quantity</strong>
                                </td>
                                <td style="border: 1px solid #000; padding: 5px; text-align: right;">
                                    <strong>
                                        <span t-esc="'%.2f' % totals['qty_available']"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px;">
                                    <strong>Total Free Quantity</strong>
                                </td>
                                <td style="border: 1px solid #000; padding: 5px; text-align: right;">
                                    <strong>
                                        <span t-esc="'%.2f' % totals['free_qty']"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px;">
                                    <strong>Total Incoming Quantity</strong>
                                </td>
                                <td style="border: 1px solid #000; padding: 5px; text-align: right;">
                                    <strong>
                                        <span t-esc="'%.2f' % totals['incoming_qty']"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px;">
                                    <strong>Total Outgoing Quantity</strong>
                                </td>
                                <td style="border: 1px solid #000; padding: 5px; text-align: right;">
                                    <strong>
                                        <span t-esc="'%.2f' % totals['outgoing_qty']"/>
                                    </strong>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>